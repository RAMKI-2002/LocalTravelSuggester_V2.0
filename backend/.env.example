# =====================================================================
# Local Travel Suggester — environment variables template
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# ---- Auth -----------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_HOURS=24

# ---- External APIs --------------------------------------------------
OPENWEATHER_API_KEY=your-openweather-api-key
FOURSQUARE_API_KEY=your-foursquare-api-key
FOURSQUARE_ENABLED=true
NOMINATIM_USER_AGENT=local-trip-suggester/2.0 (contact@example.com)

# ---- AWS Bedrock (LLM) ---------------------------------------------
# Leave blank if running on EC2/ECS with an IAM role (boto3 auto-discovers).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Set to true to skip Bedrock entirely (uses rule-based mock instead).
# Useful for local dev when AWS creds are not available.
LLM_MOCK=false

# ---- Database -------------------------------------------------------
# SQLite (default, for local dev — no setup needed):
DATABASE_URL=sqlite:///./local_travel.db

# PostgreSQL (for production — replace with your connection string):
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname?sslmode=require

# ---- Tuning ---------------------------------------------------------
HTTP_TIMEOUT_SECONDS=10.0
PLACE_CACHE_TTL_HOURS=24
WEATHER_CACHE_TTL_MINUTES=30
DEFAULT_MAX_RESULTS=5
LOG_LEVEL=INFO
